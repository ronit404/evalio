# Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Connection String
# For local MongoDB: mongodb://localhost:27017/evalio
# For MongoDB Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/evalio
MONGO_URI=mongodb://localhost:27017/evalio

# JWT Secret Key (generate a random string for production)
JWT_SECRET=evalio_super_secret_key_change_in_production_2024

# Server Port
PORT=5000

# Email Configuration (for sending exam results)
# For Gmail: smtp.gmail.com
# Note: You'll need to use an App Password if using Gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

